{
  "name": "ai-editorial-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "typecheck": "nuxt prepare && vue-tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "content:import": "node -e \"const fs=require('node:fs');const path=require('node:path');const {pathToFileURL}=require('node:url');const originalRealpathSync=fs.realpathSync.bind(fs);const originalRealpathNative=fs.realpathSync.native?fs.realpathSync.native.bind(fs.realpathSync):null;const safeRealpathSync=(target,...args)=>{try{return originalRealpathNative?originalRealpathNative(target,...args):originalRealpathSync(target,...args)}catch{return path.resolve(String(target))}};fs.realpathSync=safeRealpathSync;fs.realpathSync.native=safeRealpathSync;import(pathToFileURL(path.resolve('scripts/import-fallback-to-prisma.mjs')).href).catch((error)=>{console.error(error);process.exitCode=1})\"",
    "db:check:pg": "node scripts/check-pg-connection.mjs",
    "db:check:prisma": "node scripts/check-prisma-client.mjs",
    "stack:check": "node scripts/run-with-realpath-patch.cjs scripts/check-real-stack.mjs",
    "db:create-prisma-role": "node scripts/create-prisma-role-via-pg.mjs",
    "db:push:pg": "node scripts/apply-prisma-schema-via-pg.mjs"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "5.2.7",
    "@fontsource/space-grotesk": "5.2.10",
    "@nuxtjs/color-mode": "3.5.2",
    "@nuxtjs/tailwindcss": "6.14.0",
    "@prisma/client": "6.19.3",
    "@supabase/ssr": "0.10.2",
    "@supabase/supabase-js": "2.104.1",
    "lucide-vue-next": "1.0.0",
    "marked": "18.0.2",
    "nuxt": "3.21.2"
  },
  "devDependencies": {
    "@nuxt/eslint-config": "1.15.2",
    "eslint": "9.39.4",
    "pg": "^8.20.0",
    "prettier": "3.8.3",
    "prisma": "6.19.3",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3",
    "vue-tsc": "3.2.7"
  }
}
