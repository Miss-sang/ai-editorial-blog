generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EDITOR
}

enum ArticleStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum ProjectStatus {
  BUILDING
  LIVE
  ARCHIVED
}

enum LabStatus {
  DRAFT
  REVIEW
  LIVE
}

enum AiDraftStatus {
  IDLE
  QUEUED
  COMPLETED
  FAILED
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  avatarUrl String?
  role      UserRole  @default(EDITOR)
  articles  Article[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Article {
  id             String        @id @default(cuid())
  slug           String        @unique
  title          String
  summary        String
  excerpt        String?       @db.Text
  bodyMd         String        @db.Text
  coverImageUrl  String?
  readingTime    Int           @default(1)
  status         ArticleStatus @default(DRAFT)
  seoTitle       String?
  seoDescription String?
  isFeatured     Boolean       @default(false)
  publishedAt    DateTime?
  authorId       String?
  topicId        String?
  author         User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
  topic          Topic?        @relation(fields: [topicId], references: [id], onDelete: SetNull)
  tags           ArticleTag[]
  aiDrafts       AiDraft[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Topic {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String    @unique
  description String?
  articles    Article[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Tag {
  id        String       @id @default(cuid())
  slug      String       @unique
  name      String       @unique
  color     String?
  articles  ArticleTag[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

model Project {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  summary     String
  contentMd   String?       @db.Text
  stack       Json?
  repoUrl     String?
  demoUrl     String?
  status      ProjectStatus @default(BUILDING)
  isFeatured  Boolean       @default(false)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Lab {
  id             String    @id @default(cuid())
  slug           String    @unique
  title          String
  summary        String
  notesMd        String?   @db.Text
  scene          String
  modelProvider  String
  promptTemplate String?   @db.Text
  status         LabStatus @default(DRAFT)
  isPublic       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model AiDraft {
  id         String        @id @default(cuid())
  title      String
  provider   String        @default("longcat")
  model      String
  intent     String?
  prompt     String        @db.Text
  outlineMd  String?       @db.Text
  contentMd  String?       @db.Text
  status     AiDraftStatus @default(IDLE)
  articleId  String?
  article    Article?      @relation(fields: [articleId], references: [id], onDelete: SetNull)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model MediaAsset {
  id        String   @id @default(cuid())
  provider  String   @default("supabase")
  bucket    String
  path      String
  publicUrl String
  alt       String?
  mimeType  String?
  size      Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PageVisitLog {
  id        String   @id @default(cuid())
  path      String
  sessionId String?
  referrer  String?
  userAgent String?  @db.Text
  ipHash    String?
  source    String   @default("web")
  createdAt DateTime @default(now())

  @@index([path, createdAt])
  @@index([createdAt])
}

model SearchLog {
  id              String   @id @default(cuid())
  query           String   @db.Text
  normalizedQuery String
  resultCount     Int      @default(0)
  sessionId       String?
  referrer        String?
  userAgent       String?  @db.Text
  ipHash          String?
  createdAt       DateTime @default(now())

  @@index([normalizedQuery, createdAt])
  @@index([createdAt])
}

model AiUsageLog {
  id              String   @id @default(cuid())
  feature         String
  provider        String   @default("longcat")
  model           String?
  articleSlug     String?
  status          String
  promptLength    Int?
  selectionLength Int?
  outputLength    Int?
  durationMs      Int?
  errorMessage    String?  @db.Text
  sessionId       String?
  userAgent       String?  @db.Text
  ipHash          String?
  createdAt       DateTime @default(now())

  @@index([feature, createdAt])
  @@index([createdAt])
}
