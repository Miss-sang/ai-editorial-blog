NUXT_PUBLIC_SITE_URL=http://localhost:3000
NUXT_PUBLIC_SITE_NAME=知栈技术博客
NUXT_PUBLIC_SITE_DESCRIPTION=聚焦前端、计算机基础、浏览器、网络与 AI 平台实践的中文技术博客。

# Supabase public project URL, for example: https://<project-ref>.supabase.co
NUXT_PUBLIC_SUPABASE_URL=

# Current project code expects the legacy anon key here.
NUXT_PUBLIC_SUPABASE_ANON_KEY=

# Recommended for this Nuxt fullstack app: Supavisor session pooler string (port 5432).
# If you use prisma.<project-ref> here, first create the prisma DB role in Supabase SQL editor.
DATABASE_URL=postgres://prisma.<project-ref>:<db-password>@<region>.pooler.supabase.com:5432/postgres

# Current server-side upload flow expects the legacy service_role key here.
SUPABASE_SERVICE_ROLE_KEY=

# The upload API uses getPublicUrl, so this bucket should be public for blog cover images.
SUPABASE_STORAGE_BUCKET=blog-assets
LONGCAT_API_KEY=replace-with-your-longcat-api-key
LONGCAT_BASE_URL=https://api.longcat.chat/openai
LONGCAT_CHAT_MODEL=LongCat-Flash-Chat
LONGCAT_REASONING_MODEL=LongCat-Flash-Thinking
ADMIN_SESSION_SECRET=replace-with-a-long-random-string
ADMIN_LOGIN_EMAIL=admin@axiom-notes.dev
ADMIN_LOGIN_PASSWORD=change-me-please
ADMIN_DISPLAY_NAME=站点维护者
